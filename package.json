{
  "name": "@bnomei/emdash-action-maintenance",
  "version": "0.2.0",
  "description": "Maintenance-mode action provider plugin for EmDash.",
  "keywords": [
    "astro",
    "cloudflare",
    "cms",
    "emdash",
    "emdash-plugin",
    "maintenance",
    "serverless",
    "typescript"
  ],
  "homepage": "https://github.com/bnomei/emdash-action-maintenance#readme",
  "bugs": {
    "url": "https://github.com/bnomei/emdash-action-maintenance/issues"
  },
  "license": "MIT",
  "author": "Bruno Meilick <b@bnomei.com> (https://bnomei.com)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bnomei/emdash-action-maintenance.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack src/index.ts --format esm --dts --clean --tsconfig tsconfig.json",
    "check": "vp check .",
    "pack:check": "vp pack src/index.ts --format esm --dts --clean --tsconfig tsconfig.json --publint",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check && npm run typecheck && npm run pack:check && npm run types:check",
    "typecheck": "tsc --noEmit",
    "types:check": "attw --pack . --profile esm-only --no-summary"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "emdash": "^0.19.0",
    "publint": "^0.3.21",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.24"
  },
  "peerDependencies": {
    "emdash": ">=0.19.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.6.0"
}
